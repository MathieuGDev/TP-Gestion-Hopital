@model IEnumerable<tp_hospital.Models.Doctor>

@{
    ViewData["Title"] = "Médecins";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">🩺 Médecins <span class="badge bg-secondary fs-6">@Model.Count()</span></h1>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Tableau de bord</a>
</div>

<div class="mb-3">
    <input id="searchInput" type="text" class="form-control" placeholder="Rechercher par nom, spécialité ou département…" />
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="doctorsTable">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Spécialité</th>
                    <th>Département</th>
                    <th>N° licence</th>
                    <th class="text-center">Consultations</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doctor in Model)
                {
                    <tr style="cursor:pointer"
                        onclick="window.location='@Url.Action("DoctorDetail","Dashboard",new{id=doctor.Id})'">
                        <td class="fw-semibold">@doctor.LastName</td>
                        <td>@doctor.FirstName</td>
                        <td>@doctor.Specialty</td>
                        <td>
                            @if (doctor.Department != null)
                            {
                                <span class="badge bg-info text-dark">@doctor.Department.Name</span>
                            }
                        </td>
                        <td class="text-muted small font-monospace">@doctor.LicenseNumber</td>
                        <td class="text-center">
                            <span class="badge bg-success rounded-pill">@doctor.Consultations.Count</span>
                        </td>
                        <td class="text-end">
                            <a asp-controller="Dashboard" asp-action="DoctorDetail" asp-route-id="@doctor.Id"
                               class="btn btn-sm btn-outline-success" onclick="event.stopPropagation()">
                                Voir le planning
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Aucun médecin enregistré.</div>
}

@section Scripts {
<script>
    document.getElementById('searchInput').addEventListener('input', function () {
        const filter = this.value.toLowerCase();
        document.querySelectorAll('#doctorsTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
        });
    });
</script>
}
