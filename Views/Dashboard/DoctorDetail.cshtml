@model tp_hospital.Models.Doctor

@{
    ViewData["Title"] = $"Planning – Dr {Model.FirstName} {Model.LastName}";
    var statusLabels = new Dictionary<tp_hospital.Models.ConsultationStatus, (string css, string label)>
    {
        [tp_hospital.Models.ConsultationStatus.Scheduled]   = ("bg-primary",   "Planifiée"),
        [tp_hospital.Models.ConsultationStatus.InProgress]  = ("bg-warning text-dark", "En cours"),
        [tp_hospital.Models.ConsultationStatus.Completed]   = ("bg-success",   "Terminée"),
        [tp_hospital.Models.ConsultationStatus.Cancelled]   = ("bg-secondary", "Annulée"),
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">🩺 Planning médecin</h1>
    <a asp-controller="Dashboard" asp-action="Doctors" class="btn btn-outline-secondary btn-sm">← Liste des médecins</a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">Dr @Model.FirstName @Model.LastName</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-6 col-lg-3">
                <div class="text-muted small">Spécialité</div>
                <div class="fw-semibold">@Model.Specialty</div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="text-muted small">Département</div>
                <div class="fw-semibold">
                    @if (Model.Department != null)
                    {
                        <span class="badge bg-info text-dark fs-6">@Model.Department.Name</span>
                    }
                    else { <span>—</span> }
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="text-muted small">N° licence</div>
                <div class="fw-semibold font-monospace">@Model.LicenseNumber</div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="text-muted small">Consultations à venir</div>
                <div class="fw-semibold">
                    <span class="badge bg-primary rounded-pill fs-6">@Model.Consultations.Count</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Consultations à venir</h5>
        <span class="text-muted small">(aujourd'hui et après, hors annulées)</span>
    </div>

    @if (Model.Consultations.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date &amp; heure</th>
                        <th>Patient</th>
                        <th>Statut</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Consultations)
                    {
                        var (css, label) = statusLabels[c.Status];
                        <tr>
                            <td>
                                <strong>@c.AppointmentDate.ToString("dd/MM/yyyy")</strong>
                                <span class="text-muted ms-1">@c.AppointmentDate.ToString("HH:mm")</span>
                            </td>
                            <td>
                                @if (c.Patient != null)
                                {
                                    <a asp-controller="Dashboard" asp-action="PatientDetail" asp-route-id="@c.PatientId"
                                       class="text-decoration-none fw-semibold">
                                        @c.Patient.FirstName @c.Patient.LastName
                                    </a>
                                    <br />
                                    <span class="text-muted small">Dossier #@c.Patient.FolderNumber</span>
                                }
                            </td>
                            <td><span class="badge @css">@label</span></td>
                            <td class="text-muted small">@(string.IsNullOrWhiteSpace(c.Notes) ? "—" : c.Notes)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card-body">
            <p class="text-muted mb-0">Aucune consultation à venir pour ce médecin.</p>
        </div>
    }
</div>
