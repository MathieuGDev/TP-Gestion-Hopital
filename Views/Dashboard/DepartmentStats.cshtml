@using tp_hospital.Models
@model IEnumerable<DepartmentStatViewModel>

@{
    ViewData["Title"] = "Statistiques par département";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">📊 Statistiques par département</h1>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Tableau de bord</a>
</div>

<div class="row g-3 mb-4">
    @foreach (var dept in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-secondary bg-opacity-10 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@dept.DepartmentName</h5>
                    <span class="text-muted small">Chef : @dept.HeadDoctorName</span>
                </div>
                <div class="card-body">
                    <div class="row text-center g-2">
                        <div class="col-4">
                            <div class="border rounded p-2">
                                <div class="fs-3 fw-bold text-success">@dept.DoctorCount</div>
                                <div class="text-muted small">Médecins</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border rounded p-2">
                                <div class="fs-3 fw-bold text-primary">@dept.ConsultationCount</div>
                                <div class="text-muted small">Consultations</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border rounded p-2">
                                <div class="fs-3 fw-bold text-info">@dept.UpcomingCount</div>
                                <div class="text-muted small">À venir</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">Récapitulatif</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Département</th>
                    <th>Chef de service</th>
                    <th class="text-center">Médecins</th>
                    <th class="text-center">Total consultations</th>
                    <th class="text-center">Consultations à venir</th>
                    <th class="text-center">Taux à venir</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model)
                {
                    double ratio = dept.ConsultationCount > 0
                        ? (double)dept.UpcomingCount / dept.ConsultationCount * 100
                        : 0;

                    <tr>
                        <td class="fw-semibold">@dept.DepartmentName</td>
                        <td class="text-muted">@dept.HeadDoctorName</td>
                        <td class="text-center"><span class="badge bg-success rounded-pill">@dept.DoctorCount</span></td>
                        <td class="text-center"><span class="badge bg-primary rounded-pill">@dept.ConsultationCount</span></td>
                        <td class="text-center"><span class="badge bg-info text-dark rounded-pill">@dept.UpcomingCount</span></td>
                        <td class="text-center">
                            <div class="progress" style="height:8px;min-width:80px">
                                <div class="progress-bar bg-info" role="progressbar"
                                     style="width:@ratio.ToString("F0")%"
                                     aria-valuenow="@ratio.ToString("F0")" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <span class="text-muted small">@ratio.ToString("F0") %</span>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-semibold">
                <tr>
                    <td>Total</td>
                    <td>—</td>
                    <td class="text-center">@Model.Sum(d => d.DoctorCount)</td>
                    <td class="text-center">@Model.Sum(d => d.ConsultationCount)</td>
                    <td class="text-center">@Model.Sum(d => d.UpcomingCount)</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
